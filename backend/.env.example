# ============================================================================
# CONEXÃO COM SQL SERVER
# Copie este arquivo para .env (mesma pasta) e ajuste para a sua máquina.
# ============================================================================

SECRET_KEY=troque-essa-chave-em-producao
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# -----------------------------------------------------------------------------
# OPÇÃO 1 – Autenticação SQL Server (usuário e senha)
# Substitua: USUARIO, SENHA, SERVIDOR, NOME_DO_BANCO
# Se for instância nomeada use SERVIDOR\INSTANCIA (ex.: localhost\SQLEXPRESS)
# -----------------------------------------------------------------------------
DATABASE_URL=mssql+pyodbc://USUARIO:SENHA@SERVIDOR/NOME_DO_BANCO?driver=ODBC+Driver+17+for+SQL+Server

# -----------------------------------------------------------------------------
# OPÇÃO 2 – Autenticação do Windows (Trusted Connection)
# Comente a OPÇÃO 1 acima e descomente a linha abaixo:
# -----------------------------------------------------------------------------
# DATABASE_URL=mssql+pyodbc://@SERVIDOR/NOME_DO_BANCO?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes

# -----------------------------------------------------------------------------
# Exemplos práticos:
#   - SQL Server local autenticação SQL:
#       mssql+pyodbc://sa:MinhaSenha@localhost/TaskSyncDB?driver=ODBC+Driver+17+for+SQL+Server
#   - SQL Server Express com Windows Auth:
#       mssql+pyodbc://@localhost\SQLEXPRESS/TaskSyncDB?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes
#   - Servidor remoto:
#       mssql+pyodbc://triade:Senha%40123@10.0.0.5/TaskSyncDB?driver=ODBC+Driver+17+for+SQL+Server
# Obs.: caracteres especiais na senha precisam ser URL-encoded (ex.: @ -> %40).
# -----------------------------------------------------------------------------
